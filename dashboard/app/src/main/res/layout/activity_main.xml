<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.homehub.dashboard.ui.StarfieldView
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@color/banner_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="4dp">

            <TextView
                android:id="@+id/tv_clock"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/jetbrains_mono"
                android:textColor="@color/neon_cyan"
                android:textSize="26sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btn_settings"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/settings"
                android:src="@drawable/ic_more_vert"
                android:tint="@color/neon_cyan" />
        </LinearLayout>

                <com.homehub.dashboard.ui.GlowCardLayout
            android:id="@+id/glow_card_weather"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1.3"
            android:layout_marginTop="8dp">
    <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/card_surface_cyan"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:fontFamily="@font/jetbrains_mono"
                            android:letterSpacing="0.2"
                            android:text="7 DAY WEATHER"
                            android:textColor="@color/neon_cyan"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_weather_location"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:fontFamily="@font/jetbrains_mono"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                    </RelativeLayout>

                    <LinearLayout
                        android:id="@+id/weather_row"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal"
                        android:weightSum="7" />
                </LinearLayout>
            </FrameLayout>
        </com.homehub.dashboard.ui.GlowCardLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1.2"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:weightSum="4">

                        <com.homehub.dashboard.ui.GlowCardLayout
                android:id="@+id/glow_card_hub"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.3">
    <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/card_surface_purple"
                    android:padding="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/jetbrains_mono"
                            android:letterSpacing="0.2"
                            android:text="LIVE HUB"
                            android:textColor="@color/neon_purple"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_hub_status"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_hub_last_updated"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/jetbrains_mono"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/tv_hub_transfer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:textColor="@color/text_primary"
                            android:textSize="11sp" />

                        <ScrollView
                            android:id="@+id/scroll_hub_logs"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:layout_marginTop="4dp"
                            android:fillViewport="true">

                            <TextView
                                android:id="@+id/tv_hub_logs"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/jetbrains_mono"
                                android:lineSpacingExtra="0dp"
                                android:textColor="@color/text_secondary"
                                android:textSize="10sp" />
                        </ScrollView>
                    </LinearLayout>
                </FrameLayout>
            </com.homehub.dashboard.ui.GlowCardLayout>

                        <com.homehub.dashboard.ui.GlowCardLayout
                android:id="@+id/glow_card_finance"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.9">
    <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/card_surface_cyan"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="0dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/jetbrains_mono"
                            android:letterSpacing="0.2"
                            android:text="FINANCE"
                            android:textColor="@color/neon_cyan"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_finance_period"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/jetbrains_mono"
                            android:text="OFFLINE"
                            android:textColor="@color/text_secondary"
                            android:textSize="8sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="bottom"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/jetbrains_mono"
                            android:text="INCOME"
                            android:textColor="@color/neon_green"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_finance_income"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/jetbrains_mono"
                            android:gravity="end"
                            android:text="--"
                            android:textAlignment="viewEnd"
                            android:textColor="@color/neon_green"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="bottom"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/jetbrains_mono"
                            android:text="EXPENSE"
                            android:textColor="@color/cat_alert_neon"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_finance_expense"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/jetbrains_mono"
                            android:gravity="end"
                            android:text="--"
                            android:textAlignment="viewEnd"
                            android:textColor="@color/cat_alert_neon"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="bottom"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/jetbrains_mono"
                            android:text="BALANCE"
                            android:textColor="@color/neon_amber"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_finance_bal"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/jetbrains_mono"
                            android:gravity="end"
                            android:text="--"
                            android:textAlignment="viewEnd"
                            android:textColor="@color/neon_amber"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="3dp"
                        android:layout_marginBottom="3dp"
                        android:background="#22FFFFFF" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="bottom"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/jetbrains_mono"
                            android:text="SAVINGS"
                            android:textColor="@color/neon_cyan"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_finance_savings"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/jetbrains_mono"
                            android:gravity="end"
                            android:text="--"
                            android:textAlignment="viewEnd"
                            android:textColor="@color/neon_cyan"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </com.homehub.dashboard.ui.GlowCardLayout>

                        <com.homehub.dashboard.ui.GlowCardLayout
                android:id="@+id/glow_card_timesheet"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.9">
    <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/card_surface_green"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="0dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/jetbrains_mono"
                            android:letterSpacing="0.2"
                            android:text="TIMESHEET"
                            android:textColor="@color/neon_green"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_timesheet_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/jetbrains_mono"
                            android:text="OFFLINE"
                            android:textColor="@color/text_secondary"
                            android:textSize="8sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_timesheet_today_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="-3dp"
                        android:fontFamily="@font/jetbrains_mono"
                        android:letterSpacing="0.1"
                        android:text=""
                        android:textColor="@color/neon_green"
                        android:textSize="8sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="bottom"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_timesheet_hours"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/jetbrains_mono"
                            android:text=""
                            android:textColor="@color/text_secondary"
                            android:textSize="8sp" />

                        <TextView
                            android:id="@+id/tv_timesheet_earned"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/jetbrains_mono"
                            android:gravity="end"
                            android:text="--"
                            android:textColor="@color/neon_amber"
                            android:textSize="9sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:layout_marginTop="5dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/ll_timesheet_am"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical" />

                        <LinearLayout
                            android:id="@+id/ll_timesheet_pm"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical" />
                    </LinearLayout>
                </LinearLayout>
            </com.homehub.dashboard.ui.GlowCardLayout>

                        <com.homehub.dashboard.ui.GlowCardLayout
                android:id="@+id/glow_card_camera"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.9">
    <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/card_surface_purple"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:fontFamily="@font/jetbrains_mono"
                            android:letterSpacing="0.2"
                            android:text="CAMERA"
                            android:textColor="@color/neon_purple"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <ImageButton
                            android:id="@+id/btn_camera_mute"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentTop="true"
                            android:background="@android:color/transparent"
                            android:contentDescription="Mute camera"
                            android:padding="2dp"
                            android:src="@drawable/ic_volume_off"
                            android:tint="@color/neon_purple" />
                    </RelativeLayout>

                    <TextView
                        android:id="@+id/tv_camera_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="-3dp"
                        android:fontFamily="@font/jetbrains_mono"
                        android:text="live view"
                        android:textAlignment="viewStart"
                        android:textColor="@color/text_secondary"
                        android:textSize="8sp" />

                    <FrameLayout
                        android:id="@+id/camera_preview_container"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="8dp"
                        android:background="#14000000"
                        android:foregroundGravity="center"
                        android:paddingStart="2dp"
                        android:paddingEnd="2dp">

                        <androidx.media3.ui.PlayerView
                            android:id="@+id/player_camera"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:clickable="true"
                            android:focusable="true"
                            android:keepScreenOn="false"
                            app:resize_mode="zoom"
                            app:surface_type="texture_view" />

                        <TextView
                            android:id="@+id/tv_camera_overlay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:fontFamily="@font/jetbrains_mono"
                            android:text="[ camera ]"
                            android:textColor="@color/neon_purple"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </FrameLayout>
                </LinearLayout>
            </com.homehub.dashboard.ui.GlowCardLayout>
        </LinearLayout>

                <com.homehub.dashboard.ui.GlowCardLayout
            android:id="@+id/glow_card_alarms"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1.3"
            android:layout_marginTop="8dp">
    <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/card_surface_green"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/jetbrains_mono"
                        android:letterSpacing="0.2"
                        android:text="WEEKLY ALARMS"
                        android:textColor="@color/neon_green"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/day_card_container"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal" />
                </LinearLayout>
            </FrameLayout>
        </com.homehub.dashboard.ui.GlowCardLayout>
    </LinearLayout>

    <View
        android:id="@+id/dim_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0"
        android:background="#000000"
        android:clickable="false"
        android:focusable="false" />

</FrameLayout>
