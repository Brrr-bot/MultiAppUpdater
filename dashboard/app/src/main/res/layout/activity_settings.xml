<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_space"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:background="@color/banner_bg"
            android:paddingHorizontal="16dp">

            <Button
                android:id="@+id/btn_back"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="BACK" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="SETTINGS"
                android:textColor="@color/neon_amber"
                android:textSize="18sp"
                android:fontFamily="monospace"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/neon_card_amber"
            android:orientation="vertical"
            android:padding="16dp">

            <EditText
                android:id="@+id/et_location_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Weather location name" />

            <EditText
                android:id="@+id/et_latitude"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Latitude"
                android:inputType="numberDecimal|numberSigned" />

            <EditText
                android:id="@+id/et_longitude"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Longitude"
                android:inputType="numberDecimal|numberSigned" />

            <EditText
                android:id="@+id/et_hub_host"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Hub host"
                android:inputType="textUri" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Idle brightness" />
            <SeekBar
                android:id="@+id/seek_idle_brightness"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Active brightness" />
            <SeekBar
                android:id="@+id/seek_active_brightness"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Idle timeout seconds" />
            <SeekBar
                android:id="@+id/seek_idle_timeout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="120" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Brightness fade x100ms" />
            <SeekBar
                android:id="@+id/seek_brightness_fade"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="50" />

            <Switch
                android:id="@+id/switch_full_black"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Allow full black idle mode" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Default alarm fade seconds" />
            <SeekBar
                android:id="@+id/seek_default_fade"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="300" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Default target volume" />
            <SeekBar
                android:id="@+id/seek_default_volume"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Default snooze minutes" />
            <SeekBar
                android:id="@+id/seek_default_snooze"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="30" />

            <Button
                android:id="@+id/btn_pick_default_sound"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Pick Default Wake Sound" />

            <TextView
                android:id="@+id/tv_default_sound"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="monospace" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_accessibility"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Accessibility" />

                <Button
                    android:id="@+id/btn_battery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="Battery" />

                <Button
                    android:id="@+id/btn_save"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="Save" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
