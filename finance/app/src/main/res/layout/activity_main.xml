<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="@color/bg_space">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/banner_bg"
        android:elevation="4dp">

        <!-- Title + balance -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="10dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="▶  FINANCES"
                android:textColor="@color/neon_sky"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/jetbrains_mono"
                android:letterSpacing="0.08"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/tvTopSavings"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0.00"
                    android:textColor="@color/neon_green"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/jetbrains_mono"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="savings"
                    android:textColor="@color/text_label"
                    android:textSize="9sp"
                    android:layout_gravity="end"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tvTopBalance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0.00"
                    android:textColor="@color/neon_gold"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/jetbrains_mono"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="this month"
                    android:textColor="@color/text_label"
                    android:textSize="11sp"
                    android:layout_gravity="end"/>

            </LinearLayout>
        </LinearLayout>

        <!-- Tabs -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <TextView
                    android:id="@+id/btnTabAdd"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ADD"
                    android:textColor="@color/neon_sky"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/jetbrains_mono"
                    android:letterSpacing="0.1"
                    android:paddingTop="6dp"
                    android:paddingBottom="8dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:background="?attr/selectableItemBackground"/>

                <View
                    android:id="@+id/tabIndicatorAdd"
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="@color/neon_sky"
                    android:visibility="visible"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <TextView
                    android:id="@+id/btnTabHistory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HISTORY"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/jetbrains_mono"
                    android:letterSpacing="0.1"
                    android:paddingTop="6dp"
                    android:paddingBottom="8dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:background="?attr/selectableItemBackground"/>

                <View
                    android:id="@+id/tabIndicatorHistory"
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="@color/neon_sky"
                    android:visibility="invisible"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <TextView
                    android:id="@+id/btnTabSummary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SUMMARY"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/jetbrains_mono"
                    android:letterSpacing="0.1"
                    android:paddingTop="6dp"
                    android:paddingBottom="8dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:background="?attr/selectableItemBackground"/>

                <View
                    android:id="@+id/tabIndicatorSummary"
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="@color/neon_sky"
                    android:visibility="invisible"/>

            </LinearLayout>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/neon_sky"/>

    </LinearLayout>
        <!-- ── Aurora notification card — pulses until tapped ─────────────────── -->
        <com.mcubi.finances.GlowCardLayout
            android:id="@+id/glow_notify"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="8dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/card_surface_alert"
                android:paddingStart="14dp"
                android:paddingEnd="8dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp">

                <TextView
                    android:id="@+id/tvNotifyMsg"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:fontFamily="@font/jetbrains_mono"
                    android:lineSpacingMultiplier="1.3"/>

                <TextView
                    android:id="@+id/btnNotifyDismiss"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:text="✕"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:background="?attr/selectableItemBackgroundBorderless"/>

            </LinearLayout>
        </com.mcubi.finances.GlowCardLayout>

    <!-- Content -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/nestedScroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:clipChildren="false"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:clipChildren="false"
                android:clipToPadding="false">

                <!-- ── ADD TAB ── -->
                <com.mcubi.finances.GlowCardLayout
                    android:id="@+id/glow_card_add"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="28dp"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                <LinearLayout
                    android:id="@+id/layoutAdd"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_surface_cyan"
                    android:padding="12dp"
                    android:paddingBottom="32dp"
                    android:visibility="visible">

                    <!-- In / Out toggle -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:id="@+id/btnDirIn"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="▲  MONEY IN"
                            android:textColor="@color/neon_green"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/jetbrains_mono"
                            android:letterSpacing="0.05"
                            android:background="@drawable/btn_in_active"
                            android:layout_marginEnd="6dp"/>

                        <TextView
                            android:id="@+id/btnDirOut"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="▼  MONEY OUT"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/jetbrains_mono"
                            android:letterSpacing="0.05"
                            android:background="@drawable/btn_out_inactive"
                            android:layout_marginStart="6dp"/>

                    </LinearLayout>

                    <!-- Amount -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AMOUNT"
                        android:textColor="@color/text_label"
                        android:textSize="9sp"
                        android:fontFamily="@font/jetbrains_mono"
                        android:letterSpacing="0.2"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/etAmount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="0.00"
                        android:inputType="numberDecimal"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="20sp"
                        android:fontFamily="@font/jetbrains_mono"
                        android:background="@color/card_bg"
                        android:padding="12dp"
                        android:layout_marginBottom="16dp"/>

                    <!-- Date -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DATE"
                        android:textColor="@color/text_label"
                        android:textSize="9sp"
                        android:fontFamily="@font/jetbrains_mono"
                        android:letterSpacing="0.2"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:id="@+id/tvDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:textSize="14sp"
                        android:fontFamily="@font/jetbrains_mono"
                        android:textColor="@color/text_primary"
                        android:background="@color/card_bg"
                        android:layout_marginBottom="16dp"
                        android:clickable="true"
                        android:focusable="true"/>

                    <!-- Description -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DESCRIPTION"
                        android:textColor="@color/text_label"
                        android:textSize="9sp"
                        android:fontFamily="@font/jetbrains_mono"
                        android:letterSpacing="0.2"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/etWhat"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="e.g. Lunch, Salary, Rent…"
                        android:inputType="text"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="14sp"
                        android:fontFamily="@font/jetbrains_mono"
                        android:background="@color/card_bg"
                        android:padding="12dp"
                        android:layout_marginBottom="16dp"/>

                    <!-- Category -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CATEGORY"
                        android:textColor="@color/text_label"
                        android:textSize="9sp"
                        android:fontFamily="@font/jetbrains_mono"
                        android:letterSpacing="0.2"
                        android:layout_marginBottom="6dp"/>

                    <!-- Category buttons row 1 -->
                    <LinearLayout
                        android:id="@+id/catRow1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp"/>

                    <!-- Category buttons row 2 -->
                    <LinearLayout
                        android:id="@+id/catRow2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp"/>

                    <!-- Category buttons row 3 -->
                    <LinearLayout
                        android:id="@+id/catRow3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp"/>

                    <!-- OCR scan button -->
                    <TextView
                        android:id="@+id/btnScanReceipt"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:gravity="center"
                        android:text="SCAN RECEIPT / SCREENSHOT"
                        android:textColor="@color/neon_sky"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/jetbrains_mono"
                        android:letterSpacing="0.12"
                        android:background="@drawable/btn_scan"
                        android:layout_marginBottom="10dp"/>

                    <!-- Save button -->
                    <TextView
                        android:id="@+id/btnSave"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:gravity="center"
                        android:text="SAVE ENTRY"
                        android:textColor="@color/neon_sky"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/jetbrains_mono"
                        android:letterSpacing="0.15"
                        android:background="@drawable/btn_save"
                        android:layout_marginTop="4dp"/>

                    <TextView
                        android:id="@+id/tvSaveMsg"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textSize="12sp"
                        android:fontFamily="@font/jetbrains_mono"
                        android:layout_marginTop="8dp"
                        android:minHeight="18dp"/>

                </LinearLayout>
                </com.mcubi.finances.GlowCardLayout>

                <!-- ── HISTORY TAB ── -->
                <com.mcubi.finances.GlowCardLayout
                    android:id="@+id/glow_card_history"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="28dp"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                <LinearLayout
                    android:id="@+id/layoutHistory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_surface_green"
                    android:paddingBottom="32dp"
                    android:visibility="gone">

                    <!-- Summary row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:paddingBottom="0dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@color/card_bg"
                            android:padding="10dp"
                            android:layout_marginEnd="4dp">

                            <View
                                android:layout_width="3dp"
                                android:layout_height="match_parent"
                                android:background="@color/neon_sky"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="IN"
                                android:textColor="@color/text_secondary"
                                android:textSize="9sp"
                                android:fontFamily="@font/jetbrains_mono"
                                android:letterSpacing="0.1"/>

                            <TextView
                                android:id="@+id/tvSumIn"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textColor="@color/neon_green"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/jetbrains_mono"
                                android:layout_marginTop="3dp"/>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@color/card_bg"
                            android:padding="10dp"
                            android:layout_marginStart="4dp"
                            android:layout_marginEnd="4dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="OUT"
                                android:textColor="@color/text_secondary"
                                android:textSize="9sp"
                                android:fontFamily="@font/jetbrains_mono"
                                android:letterSpacing="0.1"/>

                            <TextView
                                android:id="@+id/tvSumOut"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textColor="@color/neon_red"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/jetbrains_mono"
                                android:layout_marginTop="3dp"/>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@color/card_bg"
                            android:padding="10dp"
                            android:layout_marginStart="4dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="BAL"
                                android:textColor="@color/text_secondary"
                                android:textSize="9sp"
                                android:fontFamily="@font/jetbrains_mono"
                                android:letterSpacing="0.1"/>

                            <TextView
                                android:id="@+id/tvSumBal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textColor="@color/neon_gold"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/jetbrains_mono"
                                android:layout_marginTop="3dp"/>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Month nav -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="4dp">

                        <ImageButton
                            android:id="@+id/btnPrevMonth"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_media_previous"
                            android:background="@null"
                            android:tint="@color/neon_sky"
                            android:contentDescription="Previous month"/>

                        <TextView
                            android:id="@+id/tvMonthLabel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:textColor="@color/neon_sky"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/jetbrains_mono"
                            android:letterSpacing="0.08"/>

                        <ImageButton
                            android:id="@+id/btnNextMonth"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_media_next"
                            android:background="@null"
                            android:tint="@color/neon_sky"
                            android:contentDescription="Next month"/>

                    </LinearLayout>

                    <EditText
                        android:id="@+id/etHistorySearch"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="12dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="4dp"
                        android:background="@drawable/cat_btn_inactive"
                        android:hint="SEARCH TRANSACTIONS"
                        android:inputType="text"
                        android:singleLine="true"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="11sp"
                        android:fontFamily="@font/jetbrains_mono"/>

                    <!-- Loading -->
                    <LinearLayout
                        android:id="@+id/layoutLoading"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="32dp"
                        android:visibility="gone">

                        <ProgressBar
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:indeterminateTint="@color/neon_sky"/>

                    </LinearLayout>

                    <!-- Empty -->
                    <TextView
                        android:id="@+id/tvEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="no entries this month"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:fontFamily="@font/jetbrains_mono"
                        android:gravity="center"
                        android:letterSpacing="0.05"
                        android:padding="32dp"
                        android:visibility="gone"/>

                    <!-- Entry list (built programmatically) -->
                    <LinearLayout
                        android:id="@+id/historyContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingTop="4dp"/>

                </LinearLayout>
                </com.mcubi.finances.GlowCardLayout>

                <!-- ── SUMMARY TAB ── -->
                <com.mcubi.finances.GlowCardLayout
                    android:id="@+id/glow_card_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="28dp"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                <LinearLayout
                    android:id="@+id/layoutSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_surface_purple"
                    android:paddingBottom="32dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:id="@+id/summaryContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"/>

                </LinearLayout>
                </com.mcubi.finances.GlowCardLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</LinearLayout>
