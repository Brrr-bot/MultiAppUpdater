<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="DatePickerTheme" parent="Theme.MaterialComponents.Dialog">
        <item name="colorPrimary">@color/neon_sky</item>
        <item name="colorAccent">@color/neon_sky</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_label</item>
        <item name="android:windowBackground">@color/card_bg</item>
        <item name="colorSurface">@color/card_bg</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="buttonBarPositiveButtonStyle">@style/DatePickerButtonStyle</item>
        <item name="buttonBarNegativeButtonStyle">@style/DatePickerButtonStyle</item>
    </style>

    <style name="DatePickerButtonStyle" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="Theme.Finance" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/neon_sky</item>
        <item name="colorPrimaryVariant">@color/neon_sky</item>
        <item name="colorOnPrimary">@color/bg_space</item>
        <item name="colorSecondary">@color/neon_gold</item>
        <item name="colorOnSecondary">@color/bg_space</item>
        <item name="android:colorBackground">@color/bg_space</item>
        <item name="android:windowBackground">@color/bg_space</item>
        <item name="colorSurface">@color/card_bg</item>
        <item name="colorOnSurface">@color/text_primary</item>
    </style>

    <!-- Animation style for the widget popup -->
    <style name="WidgetPopupAnimation" parent="@android:style/Animation.Dialog">
        <item name="android:windowEnterAnimation">@anim/slide_up</item>
        <item name="android:windowExitAnimation">@anim/slide_down</item>
    </style>

    <!-- Dialog-style theme for QuickAddActivity and WidgetSettingsActivity -->
    <style name="Theme.Finance.QuickAdd" parent="Theme.MaterialComponents.Dialog">
        <item name="android:windowBackground">@color/card_bg</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowMinWidthMajor">92%</item>
        <item name="android:windowMinWidthMinor">92%</item>
        <item name="android:windowAnimationStyle">@style/WidgetPopupAnimation</item>
        <item name="colorPrimary">@color/neon_sky</item>
        <item name="colorPrimaryVariant">@color/neon_sky</item>
        <item name="colorOnPrimary">@color/bg_space</item>
        <item name="colorSurface">@color/card_bg</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:statusBarColor">#00000000</item>
    </style>

    <!-- Aurora popup/dialog theme -->
    <style name="AuroraPopupTheme" parent="ThemeOverlay.AppCompat.Dark">
        <item name="android:colorBackground">@color/card_bg</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:popupBackground">@drawable/popup_bg_aurora</item>
        <item name="popupMenuStyle">@style/AuroraPopupMenuStyle</item>
    </style>
    <style name="AuroraPopupMenuStyle" parent="Widget.AppCompat.PopupMenu">
        <item name="android:popupBackground">@drawable/popup_bg_aurora</item>
    </style>
</resources>
