<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@color/card_bg"
    android:layout_marginBottom="6dp">

    <!-- School colour stripe -->
    <View
        android:id="@+id/viewSchoolColor"
        android:layout_width="3dp"
        android:layout_height="match_parent"
        android:background="@color/neon_sky"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <!-- Date -->
        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thu 8 May"
            android:textColor="@color/text_label"
            android:textSize="11sp"
            android:fontFamily="@font/jetbrains_mono"
            android:letterSpacing="0.05"
            android:layout_marginBottom="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- School + detail -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvSchoolName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tan Thoi Hoa"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/jetbrains_mono"/>

                <TextView
                    android:id="@+id/tvSessionDetail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 periods × 45 min"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:fontFamily="@font/jetbrains_mono"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>

            <!-- Hours + earnings -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/tvSessionHours"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2.25 hrs"
                    android:textColor="@color/neon_sky"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/jetbrains_mono"/>

                <TextView
                    android:id="@+id/tvSessionEarnings"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#8363; 1,170,000"
                    android:textColor="@color/neon_gold"
                    android:textSize="12sp"
                    android:fontFamily="@font/jetbrains_mono"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
